  "info": {
    "title": "Happit API",
    "description": "Happit API description",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateHabitDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the habit"
          },
          "type": {
            "type": "string",
            "description": "The type of the habit",
            "default": "none"
          },
          "description": {
            "type": "string",
            "description": "The description of the habit"
          },
          "archiveStatus": {
            "type": "boolean",
            "description": "The archive status of the habit",
            "default": false
          },
          "repeatType": {
            "type": "string",
            "description": "The repeat type of the habit",
            "enum": [
              "daily",
              "weekly"
            ]
          },
          "repeatDay": {
            "type": "array",
            "description": "The repeat days of the habit",
            "items": {
              "type": "string",
              "enum": [
                "mon",
                "tue",
                "wed",
                "thu",
                "fri",
                "sat",
                "sun"
              ]
            }
          }
        },
        "required": [
          "name",
          "repeatType"
        ]
      },
      "UpdateHabitDTO": {
        "type": "object",
        "properties": {}
      },
      "CreateOrUpdateRecordDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Record date (YYYY-MM-DD)",
            "example": "2025-02-15"
          },
          "habitId": {
            "type": "number",
            "description": "Habit id"
          },
          "state": {
            "type": "string",
            "description": "Completion state",
            "enum": [
              "done",
              "notDone",
              "skipped"
            ]
          }
        },
        "required": [
          "date",
          "habitId",
          "state"
        ]
      },
      "GrassRecordItemDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "example": "2025-02-15"
          },
          "state": {
            "type": "string",
            "enum": [
              "done",
              "notDone",
              "skipped"
            ]
          }
        },
        "required": [
          "date",
          "state"
        ]
      },
      "GrassItemDto": {
        "type": "object",
        "properties": {
          "habitId": {
            "type": "number"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GrassRecordItemDto"
            }
          }
        },
        "required": [
          "habitId",
          "records"
        ]
      }
    }
  }
}